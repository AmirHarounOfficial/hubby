# =============================================================================
# HubbyGlobal — PRODUCTION environment
# -----------------------------------------------------------------------------
# Copy this file to ".env" on the server (same folder as docker-compose.yml)
# and fill in every value marked CHANGE_ME. This single file is read by BOTH
# docker-compose (for the mysql service) AND injected into the Laravel
# containers (app / horizon / scheduler) via `env_file`.
#
#   cp .env.production.example .env
#   nano .env
#
# Generate APP_KEY once (after the images are built):
#   docker compose run --rm app php artisan key:generate --show
# then paste the "base64:..." value into APP_KEY below.
# =============================================================================

# --- Application ---------------------------------------------------------------
APP_NAME=HubbyGlobal
APP_ENV=production
APP_KEY=                                  # CHANGE_ME  (base64:... — see header)
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://hubbynetwork.com
FRONTEND_URL=https://hubbynetwork.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# --- Logging -------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- Database (MySQL container) ------------------------------------------------
# DB_USERNAME must NOT be "root" (MySQL creates this as a separate user).
# These three values are also used by the mysql service in docker-compose.yml.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hubby_global
DB_USERNAME=hubby
DB_PASSWORD=CHANGE_ME_strong_db_password

# --- Cache / Queue / Session (Redis) ------------------------------------------
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Sanctum (API auth) --------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=hubbynetwork.com
SESSION_DOMAIN=.hubbynetwork.com

# --- Mail (configure with your SMTP provider) ----------------------------------
MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME_smtp_host
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@hubbynetwork.com
MAIL_FROM_NAME="${APP_NAME}"

# --- Store integrations --------------------------------------------------------
# Each platform's *_CLIENT_ID/SECRET are YOUR app credentials (from that
# platform's developer portal). They power the one-click "Connect with X" button.
# Leave them blank to launch — merchants can still connect by pasting their own
# API token in the dashboard. *_WEBHOOK_SECRET verifies inbound webhooks (HMAC);
# leave blank to skip verification (a warning is logged).
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_WEBHOOK_SECRET=                    # optional; defaults to SHOPIFY_CLIENT_SECRET

SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=
SALLA_WEBHOOK_SECRET=

WOO_CLIENT_ID=
WOO_CLIENT_SECRET=
WOO_WEBHOOK_SECRET=

ZID_CLIENT_ID=
ZID_CLIENT_SECRET=
ZID_WEBHOOK_SECRET=

# Amazon Selling Partner API (SP-API) — Login with Amazon + SP-API app creds.
AMAZON_APP_ID=
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_SELLER_ID=
AMAZON_MARKETPLACE_ID=
AMAZON_REGION=na                           # na | eu | fe
AMAZON_WEBHOOK_SECRET=

# noon Seller (Partner) API — hosts are env-driven (fill from your noon account).
NOON_CLIENT_ID=
NOON_CLIENT_SECRET=
NOON_AUTH_URL=https://accounts.noon.partners
NOON_BASE_URL=https://api.noon.partners
NOON_WEBHOOK_SECRET=

# --- Payments (edfapay) --------------------------------------------------------
# Leave blank to launch with simulated activation; fill to enable real checkout.
# Sandbox base URL: https://sandbox.edfapay.com  ·  Live: https://api.edfapay.com
EDFAPAY_MERCHANT_KEY=
EDFAPAY_PASSWORD=
EDFAPAY_BASE_URL=https://sandbox.edfapay.com
EDFAPAY_CURRENCY=SAR
